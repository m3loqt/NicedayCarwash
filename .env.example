# Copy to .env and fill values. Never commit .env.
# For EAS builds: set the same keys as EAS Secrets or env in eas.json (EXPO_PUBLIC_* are embedded at build time).

# Firebase (required for app to start — see EnvConfigurationError in app/_layout.tsx)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_SITE_KEY=

# Google OAuth (optional — enable only with GOOGLE_SIGN_IN_ENABLED in app/index.tsx)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
