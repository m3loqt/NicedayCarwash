{
  "expo": {
    "name": "NicedayCarwash",
    "slug": "NicedayCarwash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nd_appicon.png",
    "scheme": "nicedaycarwash",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nicedaycarwash.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F9EF08",
        "foregroundImage": "./assets/images/nd_appicon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nicedaycarwash.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/nd_appicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ndcwlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9EF08",
          "dark": {
            "backgroundColor": "#F9EF08"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NicedayCarwash to use your location to show nearby branches."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NicedayCarwash to access your photos to set your profile picture.",
          "cameraPermission": "Allow NicedayCarwash to use the camera for your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
